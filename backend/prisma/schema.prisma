// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  users             User[]
  roles             Role[]
  pipelineTemplates PipelineTemplate[]
  pipelineStages    PipelineStage[]
  candidates        Candidate[]
  evaluations       Evaluation[]
  decisions         Decision[]
  slaAlerts         SlaAlert[]
  jobs              Job[]
  interviews        Interview[]
  auditLogs         AuditLog[]
  notifications     Notification[]
}

model Role {
  id       String @id @default(uuid())
  tenantId String
  name     String // e.g., 'ADMIN', 'RECRUITER', 'INTERVIEWER'

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users  User[]

  @@unique([tenantId, name])
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  roleId       String
  email        String
  passwordHash String
  firstName    String   @default("")
  lastName     String   @default("")
  createdAt    DateTime @default(now())

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Restrict)
  evaluations  Evaluation[]
  interviews   Interview[]
  auditLogs    AuditLog[]
  notifications Notification[]
  managedJobs  Job[]        @relation("HiringManager")
  assignedCandidates Candidate[] @relation("AssignedRecruiter")

  @@unique([tenantId, email])
}

model Job {
  id                 String   @id @default(uuid())
  tenantId           String
  title              String
  department         String   @default("")
  hiringManagerId    String?
  pipelineTemplateId String?
  status             String   @default("OPEN") // OPEN, CLOSED, ARCHIVED
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant             Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  hiringManager      User?             @relation("HiringManager", fields: [hiringManagerId], references: [id], onDelete: SetNull)
  pipelineTemplate   PipelineTemplate? @relation(fields: [pipelineTemplateId], references: [id], onDelete: SetNull)
  candidates         Candidate[]

  @@index([tenantId, status])
}

model PipelineTemplate {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  roleType  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stages     PipelineStage[]
  candidates Candidate[]
  jobs       Job[]

  @@unique([tenantId, name])
}

model PipelineStage {
  id                 String   @id @default(uuid())
  tenantId           String
  pipelineTemplateId String
  name               String
  orderIndex         Int
  slaHours           Int      @default(48) // Default 48h SLA for bottleneck
  stageType          String   @default("INTERVIEW") // STATIC, INTERVIEW, ASSESSMENT, AUTOMATED

  tenant             Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pipelineTemplate   PipelineTemplate @relation(fields: [pipelineTemplateId], references: [id], onDelete: Cascade)
  candidates         Candidate[]
  evaluations        Evaluation[]
  interviews         Interview[]

  @@unique([pipelineTemplateId, orderIndex])
}

model Candidate {
  id             String   @id @default(uuid())
  tenantId       String
  pipelineId     String
  jobId          String?
  currentStageId String?
  firstName      String
  lastName       String
  email          String
  resumeUrl      String?
  status         String   @default("ACTIVE") // ACTIVE, REJECTED, HIRED, ON_HOLD
  stageEnteredAt DateTime @default(now())
  stageHistory   Json?     @default("[]")
  createdAt      DateTime @default(now())
  assignedRecruiterId String?
  
  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pipeline     PipelineTemplate @relation(fields: [pipelineId], references: [id], onDelete: Restrict)
  job          Job?             @relation(fields: [jobId], references: [id], onDelete: SetNull)
  currentStage PipelineStage?   @relation(fields: [currentStageId], references: [id], onDelete: SetNull)
  assignedRecruiter User?      @relation("AssignedRecruiter", fields: [assignedRecruiterId], references: [id], onDelete: SetNull)
  evaluations  Evaluation[]
  decisions    Decision[]
  slaAlerts    SlaAlert[]
  interviews   Interview[]

  @@index([tenantId, pipelineId, currentStageId])
  @@index([tenantId, status])
  @@index([tenantId, assignedRecruiterId])
}

model Evaluation {
  id             String   @id @default(uuid())
  tenantId       String
  candidateId    String
  stageId        String
  interviewerId  String
  scores         Json     // Flexible scorecard (JSONB)
  recommendation String   // 'STRONG_HIRE', 'HIRE', 'NO_HIRE'
  createdAt      DateTime @default(now())

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  candidate   Candidate     @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  stage       PipelineStage @relation(fields: [stageId], references: [id], onDelete: SetNull)
  interviewer User          @relation(fields: [interviewerId], references: [id], onDelete: Restrict)
}

model Decision {
  id            String   @id @default(uuid())
  tenantId      String
  candidateId   String
  finalDecision String   // 'HIRE', 'NO_HIRE'
  hasConflict   Boolean  @default(false)
  decisionNotes String?
  createdAt     DateTime @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model SlaAlert {
  id           String   @id @default(uuid())
  tenantId     String
  candidateId  String
  stageId      String
  alertMessage String
  isResolved   Boolean  @default(false)
  createdAt    DateTime @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model Interview {
  id             String   @id @default(uuid())
  tenantId       String
  candidateId    String
  stageId        String
  interviewerId  String
  scheduledAt    DateTime
  feedbackStatus String   @default("PENDING") // PENDING, SUBMITTED
  notes          String?
  createdAt      DateTime @default(now())

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  candidate   Candidate     @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  stage       PipelineStage @relation(fields: [stageId], references: [id], onDelete: SetNull)
  interviewer User          @relation(fields: [interviewerId], references: [id], onDelete: Restrict)

  @@index([tenantId, candidateId])
  @@index([tenantId, interviewerId])
}

model AuditLog {
  id         String   @id @default(uuid())
  tenantId   String
  userId     String?
  action     String   // CREATE, UPDATE, DELETE, VIEW, EXPORT, LOGIN
  resource   String   // Candidate, Job, Evaluation
  resourceId String?
  changes    Json?    // Stores before/after values
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, resource, resourceId])
  @@index([tenantId, createdAt])
}

model Notification {
  id        String   @id @default(uuid())
  tenantId  String
  userId    String
  type      String   // 'SLA_VIOLATION', 'INTERVIEW_SCHEDULED', 'FEEDBACK_REQUIRED', 'DECISION_MADE'
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, isRead])
}
