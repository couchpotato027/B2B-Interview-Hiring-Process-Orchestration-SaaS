		{
			"name": "Candidates",
			"item": [
				{
					"name": "Upload Resume",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "X-Tenant-Id",
								"value": "{{tenantId}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "resume",
									"type": "file",
									"src": "/path/to/resume.pdf"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/candidates/upload",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"candidates",
								"upload"
							]
						}
					},
					"response": []
				},
				{
					"name": "List Candidates",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "X-Tenant-Id",
								"value": "{{tenantId}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{baseUrl}}/api/v1/candidates?page=1&limit=10",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"candidates"
							],
							"query": [
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "limit",
									"value": "10"
								}
							]
						}
					},
					"response": []
				}
			]
		},
		{
			"name": "Evaluations",
			"item": [
				{
					"name": "Evaluate Candidate",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "X-Tenant-Id",
								"value": "{{tenantId}}",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"candidateId\": \"{{candidateId}}\",\n    \"jobId\": \"{{jobId}}\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/evaluations",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"v1",
								"evaluations"
							]
						}
					},
					"response": []
				}
			]
		}
	],
