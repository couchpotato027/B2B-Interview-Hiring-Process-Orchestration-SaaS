// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())

  users             User[]
  roles             Role[]
  pipelineTemplates PipelineTemplate[]
  pipelineStages    PipelineStage[]
  candidates        Candidate[]
  evaluations       Evaluation[]
  decisions         Decision[]
  slaAlerts         SlaAlert[]
}

model Role {
  id       String @id @default(uuid())
  tenantId String
  name     String // e.g., 'ADMIN', 'RECRUITER', 'INTERVIEWER'

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users  User[]

  @@unique([tenantId, name])
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  roleId       String
  email        String
  passwordHash String
  createdAt    DateTime @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role        Role         @relation(fields: [roleId], references: [id], onDelete: Restrict)
  evaluations Evaluation[]

  @@unique([tenantId, email])
}

model PipelineTemplate {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  roleType  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stages     PipelineStage[]
  candidates Candidate[]

  @@unique([tenantId, name])
}

model PipelineStage {
  id                 String @id @default(uuid())
  tenantId           String
  pipelineTemplateId String
  name               String
  orderIndex         Int
  slaHours           Int    @default(48) // Default 48h SLA for bottleneck

  tenant           Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pipelineTemplate PipelineTemplate @relation(fields: [pipelineTemplateId], references: [id], onDelete: Cascade)
  candidates       Candidate[]
  evaluations      Evaluation[]

  @@unique([pipelineTemplateId, orderIndex])
}

model Candidate {
  id             String   @id @default(uuid())
  tenantId       String
  pipelineId     String
  currentStageId String?
  firstName      String
  lastName       String
  email          String
  status         String   @default("ACTIVE") // ACTIVE, REJECTED, HIRED, ON_HOLD
  stageEnteredAt DateTime @default(now())
  version        Int      @default(1) // OCC support

  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pipeline     PipelineTemplate @relation(fields: [pipelineId], references: [id], onDelete: Restrict)
  currentStage PipelineStage?   @relation(fields: [currentStageId], references: [id], onDelete: SetNull)
  evaluations  Evaluation[]
  decisions    Decision[]
  slaAlerts    SlaAlert[]

  @@index([tenantId, pipelineId, currentStageId])
}

model Evaluation {
  id             String   @id @default(uuid())
  tenantId       String
  candidateId    String
  stageId        String
  interviewerId  String
  scores         Json // Flexible scorecard (JSONB)
  recommendation String // 'STRONG_HIRE', 'HIRE', 'NO_HIRE'
  createdAt      DateTime @default(now())

  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  candidate   Candidate     @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  stage       PipelineStage @relation(fields: [stageId], references: [id], onDelete: SetNull)
  interviewer User          @relation(fields: [interviewerId], references: [id], onDelete: Restrict)
}

model Decision {
  id            String   @id @default(uuid())
  tenantId      String
  candidateId   String
  finalDecision String // 'HIRE', 'NO_HIRE'
  hasConflict   Boolean  @default(false)
  decisionNotes String?
  createdAt     DateTime @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}

model SlaAlert {
  id           String   @id @default(uuid())
  tenantId     String
  candidateId  String
  stageId      String
  alertMessage String
  isResolved   Boolean  @default(false)
  createdAt    DateTime @default(now())

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
}
