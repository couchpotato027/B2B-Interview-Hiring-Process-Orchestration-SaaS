{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "lib": ["ES2022"],
    "types": ["node"],
    "rootDir": "./src",
    "outDir": "./dist",
    "strict": true,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true
  },
  "include": [
    "src/application/**/*.ts",
    "src/domain/**/*.ts",
    "src/infrastructure/config/**/*.ts",
    "src/infrastructure/di/**/*.ts",
    "src/infrastructure/logging/**/*.ts",
    "src/infrastructure/events/**/*.ts",
    "src/infrastructure/observers/**/*.ts",
    "src/infrastructure/parsers/**/*.ts",
    "src/infrastructure/repositories/**/*.ts",
    "src/infrastructure/services/**/*.ts",
    "src/presentation/**/*.ts",
    "src/index.ts",
    "src/shared/Result.ts",
    "src/shared/errors/**/*.ts",
    "src/shared/types/**/*.ts"
  ],
  "exclude": ["dist", "node_modules", "scripts"]
}
