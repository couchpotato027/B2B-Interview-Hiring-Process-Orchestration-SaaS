{
  "name": "hireflow-backend",
  "version": "1.0.0",
  "description": "HireFlow Backend - Unified Architecture",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --clear src/index.ts",
    "dev:debug": "NODE_ENV=development DEBUG=* ts-node-dev --inspect --respawn src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "build:clean": "rm -rf dist && tsc",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:reset": "prisma migrate reset --force",
    "db:seed": "ts-node scripts/seed-complete.ts",
    "db:studio": "prisma studio",
    "generate": "prisma generate",
    "postinstall": "prisma generate",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "diagnose": "bash scripts/diagnose.sh",
    "fix": "bash scripts/fix-all.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@aws-sdk/client-s3": "^3.1027.0",
    "@aws-sdk/lib-storage": "^3.1027.0",
    "@aws-sdk/s3-request-presigner": "^3.1027.0",
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "^5.22.0",
    "axios": "^1.6.8",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.0",
    "bullmq": "^5.73.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "fuse.js": "^7.3.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.6.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.13",
    "node-cache": "^5.1.2",
    "node-cron": "^4.2.1",
    "p-limit": "^7.3.0",
    "pdf-parse": "^1.1.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "redis": "^4.6.11",
    "socket.io": "^4.8.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.11.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/nodemailer": "^6.4.15",
    "@types/node": "^20.19.39",
    "@types/pdf-parse": "^1.1.5",
    "@types/socket.io": "^3.0.2",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
