@startuml HireFlow_UseCase

!define RECTANGLE_COLOR #F9F9F9
!define SYSTEM_COLOR #E0F2F1
!define USECASE_COLOR #FFFFFF

skinparam rectangle {
    BackgroundColor RECTANGLE_COLOR
    BorderColor #999999
}

skinparam usecase {
    BackgroundColor USECASE_COLOR
    BorderColor #2E7D32
    ArrowColor #2E7D32
}

skinparam actor {
    BackgroundColor #1976D2
    BorderColor #0D47A1
}

left to right direction

'----------------------------------------------
' ACTORS
'----------------------------------------------
actor "Admin\n(System Administrator)" as Admin
actor "Recruiter\n(HR Professional)" as Recruiter
actor "Hiring Manager\n(Department Head)" as Manager
actor "Candidate\n(Job Applicant)" as Candidate
actor "AI Service\n<<External>>" as AIService

' Generalization
Admin -|> Recruiter : extends privileges

'----------------------------------------------
' SYSTEM BOUNDARY
'----------------------------------------------
rectangle "HireFlow System" <<System>> as HireFlow {

    package "Authentication & User Management" {
        usecase "Register Account" as UC_Reg
        usecase "Login / Logout" as UC_Login
        usecase "Manage Team Members" as UC_Team
        usecase "Configure User Roles" as UC_Roles
    }
    
    package "System Administration" {
        usecase "Configure Organization Settings" as UC_OrgSettings
        usecase "Manage Pipeline Templates" as UC_ManagePipelines
        usecase "View Audit Logs" as UC_Audit
        usecase "Monitor System Health" as UC_Health
    }

    package "Job Management" {
        usecase "Create Job Posting" as UC_CreateJob
        usecase "View All Jobs" as UC_ViewJobs
        usecase "Update Job Details" as UC_UpdateJob
        usecase "Close Job" as UC_CloseJob
        usecase "Assign Hiring Manager" as UC_AssignManager
    }

    package "Candidate Management" {
        usecase "Upload Resume" as UC_UploadResume
        usecase "Add Candidate Manually" as UC_AddCand
        usecase "View Candidate Directory" as UC_Dir
        usecase "Search / Filter Candidates" as UC_SearchCand
        usecase "View Candidate Details" as UC_ViewCand
        usecase "Delete / Archive Candidate" as UC_ArchiveCand
    }

    package "Pipeline & Workflow" {
        usecase "Create Pipeline Template" as UC_CreatePipeline
        usecase "Configure Pipeline Stages" as UC_ConfigStages
        usecase "View Pipeline Board (Kanban)" as UC_Board
        usecase "Move Candidate Through Stages" as UC_MoveCand
        usecase "Bulk Move Candidates" as UC_BulkMove
        usecase "Set Stage Auto-Actions" as UC_AutoActions
    }

    package "AI-Powered Evaluation" {
        usecase "Parse Resume" as UC_ParseRes
        usecase "Evaluate Candidate Fit" as UC_EvalFit
        usecase "Generate Candidate Insights" as UC_GenInsights
        usecase "Compare Multiple Candidates" as UC_Compare
        usecase "Provide Resume Feedback" as UC_ResFeedback
    }

    package "Scoring & Ranking" {
        usecase "Calculate Skill Match Score" as UC_SkillScore
        usecase "Calculate Experience Score" as UC_ExpScore
        usecase "Calculate Project Relevance Score" as UC_ProjScore
        usecase "Rank Candidates for Job" as UC_RankCand
        usecase "View Evaluation Details" as UC_ViewEval
    }

    package "Analytics & Reporting" {
        usecase "View Dashboard Metrics" as UC_DashMetrics
        usecase "Generate Hiring Funnel Report" as UC_FunnelReport
        usecase "View Stage Drop-off Rates" as UC_Dropoff
        usecase "Analyze Time-to-Hire Trends" as UC_HireTrends
        usecase "Export Candidate Data (CSV)" as UC_ExportData
        usecase "View Skills Gap Analysis" as UC_SkillsGap
    }

    package "Notifications" {
        usecase "Receive Email Alerts" as UC_EmailAlerts
        usecase "Configure Notification Preferences" as UC_NotifPrefs
        usecase "Receive SLA Breach Alerts" as UC_SlaAlerts
    }
}

'----------------------------------------------
' EXTENDS / INCLUDES RELATIONSHIPS
'----------------------------------------------
UC_ParseRes ..> UC_UploadResume : <<extend>>
UC_EvalFit ..> UC_ParseRes : <<include>>
UC_SkillScore ..> UC_EvalFit : <<include>>
UC_ExpScore ..> UC_EvalFit : <<include>>
UC_ProjScore ..> UC_EvalFit : <<include>>
UC_RankCand ..> UC_EvalFit : <<include>>
UC_ResFeedback ..> UC_ParseRes : <<extend>>
UC_ConfigStages ..> UC_CreatePipeline : <<include>>

'----------------------------------------------
' ACTOR -> USE CASE MAPPING
'----------------------------------------------

' Candidate
Candidate --> UC_Reg
Candidate --> UC_Login
Candidate --> UC_UploadResume
Candidate --> UC_EmailAlerts
Candidate --> UC_NotifPrefs

' Admin
Admin --> UC_Team
Admin --> UC_Roles
Admin --> UC_OrgSettings
Admin --> UC_ManagePipelines
Admin --> UC_Audit
Admin --> UC_Health

' Recruiter
Recruiter --> UC_Login
Recruiter --> UC_NotifPrefs
Recruiter --> UC_EmailAlerts
Recruiter --> UC_SlaAlerts

Recruiter --> UC_CreateJob
Recruiter --> UC_ViewJobs
Recruiter --> UC_UpdateJob
Recruiter --> UC_CloseJob
Recruiter --> UC_AssignManager

Recruiter --> UC_AddCand
Recruiter --> UC_Dir
Recruiter --> UC_SearchCand
Recruiter --> UC_ViewCand
Recruiter --> UC_ArchiveCand

Recruiter --> UC_CreatePipeline
Recruiter --> UC_ConfigStages
Recruiter --> UC_Board
Recruiter --> UC_MoveCand
Recruiter --> UC_BulkMove
Recruiter --> UC_AutoActions

Recruiter --> UC_Compare
Recruiter --> UC_RankCand
Recruiter --> UC_ViewEval
Recruiter --> UC_ResFeedback

Recruiter --> UC_DashMetrics
Recruiter --> UC_FunnelReport
Recruiter --> UC_Dropoff
Recruiter --> UC_HireTrends
Recruiter --> UC_ExportData
Recruiter --> UC_SkillsGap

' Hiring Manager
Manager --> UC_Login
Manager --> UC_NotifPrefs
Manager --> UC_EmailAlerts
Manager --> UC_ViewJobs
Manager --> UC_Dir
Manager --> UC_SearchCand
Manager --> UC_ViewCand
Manager --> UC_Board
Manager --> UC_MoveCand
Manager --> UC_Compare
Manager --> UC_RankCand
Manager --> UC_ViewEval
Manager --> UC_DashMetrics

' AI Service (External)
AIService --> UC_ParseRes
AIService --> UC_EvalFit
AIService --> UC_GenInsights

@enduml
